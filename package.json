{
  "name": "@trintel/zooy",
  "version": "1.9.1",
  "description": "UI Building Blocks",
  "license": "Apache-2.0",
  "author": {
    "name": "Jan Badenhorst",
    "email": "janhendrik.badenhorst@gmail.com"
  },
  "contributors": [
    "Andries Niemandt <andries.niemandt91@gmail.com> (https://github.com/andriesniemandt)"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trinity-telecomms/zooy.git"
  },
  "files": [
    "dist",
    "src/sass"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/zooy.cjs.js",
  "module": "./dist/zooy.es.js",
  "exports": {
    ".": {
      "import": "./dist/zooy.es.js",
      "require": "./dist/zooy.cjs.js"
    },
    "./sass": "./src/sass/main.scss"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && vp build",
    "lint": "vp lint src/**/*.js",
    "lint:fix": "vp lint src/**/*.js --fix",
    "dev": "vp dev",
    "prepare": "vp config"
  },
  "dependencies": {
    "@carbon/icons": "^11.79.0",
    "@carbon/web-components": "^2.53.0",
    "@ibm/plex": "^6.4.1",
    "badu": "^8.6.0",
    "material-components-web": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.28.0",
    "esm": "^3.2.25",
    "ramda": "^0.32.0",
    "sass": "^1.99.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "npm@11.12.1"
}
